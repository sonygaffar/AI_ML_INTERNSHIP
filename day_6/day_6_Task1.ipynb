    "#Task 1\n",
    "def calc_rectangle(length, width):\n",
    "    area = length * width\n",
    "    perimeter = 2 * (length + width)\n",
    "    return area, perimeter\n",
    "length =5\n",
    "width =3\n",
    "area, perimeter = calc_rectangle(length, width)\n",
    "print(\"Area:\", area)\n",
    "print(\"Parameter:\", perimeter)"
   ]
